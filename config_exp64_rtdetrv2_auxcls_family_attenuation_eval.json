{
  "model_backend": "hf_rtdetr_v2_aux",
  "hf_model_name_or_path": "PekingU/rtdetr_v2_r50vd",
  "hf_load_strategy": "pretrained_reset_transformer",
  "hf_ignore_mismatched_sizes": true,
  "hf_eos_coefficient": 0.0001,
  "use_official_backend_postprocess": true,
  "rtdetr_postprocess_variant": "official_hf",
  "batch_size": 16,
  "train_batch_size": 24,
  "val_batch_size": 16,
  "test_batch_size": 16,
  "gradient_accumulation_steps": 1,
  "seed": 42,
  "num_epochs": 30,
  "learning_rate": 0.0001,
  "backbone_learning_rate": 1e-05,
  "weight_decay": 0.0005,
  "scheduler_type": "onecycle",
  "onecycle_pct_start": 0.2,
  "onecycle_anneal_strategy": "cos",
  "onecycle_div_factor": 25.0,
  "onecycle_final_div_factor": 10000.0,
  "num_classes": 10,
  "data_dir": "./Dataset",
  "train_image_dir": "./Dataset/train",
  "val_image_dir": "./Dataset/valid",
  "test_image_dir": "./Dataset/test",
  "train_ann_path": "./Dataset/train.json",
  "val_ann_path": "./Dataset/valid.json",
  "test_ann_path": "./Dataset/test.json",
  "checkpoint_path": "./Model_Weight/64/checkpoint_rtdetrv2_auxcls_family_attenuation_eval.pth",
  "best_model_path": "./Model_Weight/64/best_model_rtdetrv2_auxcls_family_attenuation_eval.pth",
  "best_loss_model_path": "./Model_Weight/64/best_loss_rtdetrv2_auxcls_family_attenuation_eval.pth",
  "training_curve_path": "./Plot/training_curves_rtdetrv2_auxcls_family_attenuation_eval.png",
  "prediction_path": "./Prediction/exp64_rtdetrv2_auxcls_family_attenuation_eval_pred.json",
  "resume_training": false,
  "early_stopping_patience": 6,
  "num_workers": 6,
  "train_num_workers": 8,
  "val_num_workers": 6,
  "test_num_workers": 6,
  "pin_memory": true,
  "train_pin_memory": true,
  "val_pin_memory": false,
  "test_pin_memory": false,
  "train_persistent_workers": true,
  "val_persistent_workers": false,
  "test_persistent_workers": false,
  "use_amp": true,
  "use_ema": true,
  "ema_decay": 0.9999,
  "ema_warmups": 2000,
  "enable_train_timing": false,
  "use_bucket_sampler": false,
  "max_image_size": 640,
  "train_max_image_size": 640,
  "train_fixed_image_size": [
    320,
    640
  ],
  "use_dynamic_multi_scale": false,
  "inference_max_image_size": 640,
  "inference_fixed_image_size": [
    320,
    640
  ],
  "inference_allow_upscale": false,
  "use_color_jitter": true,
  "brightness_jitter": 0.25,
  "contrast_jitter": 0.25,
  "saturation_jitter": 0.15,
  "hue_jitter": 0.03,
  "use_gamma_aug": true,
  "gamma_min": 0.8,
  "gamma_max": 1.2,
  "use_gaussian_blur": false,
  "use_light_affine_aug": true,
  "max_rotation_degree": 4.0,
  "max_translation_ratio": 0.03,
  "min_affine_scale": 0.85,
  "max_affine_scale": 1.15,
  "max_shear_degree": 2.0,
  "num_queries": 300,
  "score_threshold": 0.05,
  "use_aux_digit_classifier": true,
  "aux_digit_hidden_dim": 256,
  "aux_digit_classifier_loss_weight": 0.2,
  "query_quality_loss_weight": 0.0,
  "aux_digit_classifier_fusion_weight": 0.20,
  "use_aux_digit_classifier_gated_fusion": true,
  "aux_digit_gate_top1_threshold": 0.90,
  "aux_digit_gate_margin_threshold": 0.15,
  "use_aux_digit_confusion_family_selective_fusion": false,
  "use_aux_digit_confusion_family_attenuation": true,
  "aux_digit_confusion_families": [
    [1, 4, 7]
  ],
  "aux_digit_family_attenuation_weights": {
    "1,4,7": 0.10
  }
